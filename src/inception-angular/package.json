{
  "name": "inception-angular",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier \"**/*.{ts,scss}\" --write",
    "format:check": "prettier \"**/*.{ts,scss}\" --check ",
    "prettier:diff": "bash -lc 'set -e; failed=0; for f in $(prettier -l \"**/*.{ts,scss}\"); do prettier --stdin-filepath \"$f\" < \"$f\" | git --no-pager diff --color=always --no-index -- \"$f\" - || failed=1; done; exit $failed'",
    "test:ci": "ng test --watch=false",
    "postinstall": "cd ../.. && husky src/inception-angular/.husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/localize": "^21.2.7",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@auth0/angular-jwt": "^5.2.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "date-fns": "^4.1.0",
    "es6-template-string": "^1.2.0",
    "ngx-scrollbar": "^19.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^9.0.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/types": "^8.47.0",
    "@typescript-eslint/utils": "^8.47.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.3",
    "ng-packagr": "^21.0.1",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.16"
  }
}
