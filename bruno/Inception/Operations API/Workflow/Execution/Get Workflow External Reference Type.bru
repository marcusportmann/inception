meta {
  name: Get Workflow External Reference Type
  type: http
  seq: 1
}

get {
  url: {{baseURL}}/api/operations/reference/external-reference-types/{{externalReferenceTypeCode}}
  body: none
  auth: inherit
}

vars:pre-request {
  externalReferenceTypeCode: test_workflow_external_reference
}

assert {
  res.status: eq 200
}

settings {
  encodeUrl: true
  timeout: 0
}
